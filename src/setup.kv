<Slider>
    size_hint_x: None
    width: 300
    disabled: False
# Creates a template for the Slider with default attributes

<TextInput>
    multiline: False
    size_hint: 0.3, 0.05
    text_size: self.width, None
    halign: "left"
    valign: "center"
# Creates a template for the TextInput with default attributes

<ScreenThree>:
    FloatLayout:
        Label:
            text: "Game Setup"
            size_hint: 0.5, None
            height: 50
            pos_hint: {"center_x": 0.5, "center_y": 0.95}  # Positions at the top-center
            color: "#d73612ff"
            font_name: root.rye_font  # Font Path "assets\\fonts\\RobotoSlab-Medium.ttf"
            font_size: "50dp"  # Large Heading
        # "Game Setup" Title
            
        GridLayout:  # Layout for all the game's settings
            rows: 10
            cols: 3
            # Layout dimensions 10x3

            row_default_height: '40dp'
            row_force_default: True
            size_hint: None, None
            size: self.minimum_size
            pos_hint: {"center_x": 0.5, "center_y": 0.5}  # Positioned at the center
            spacing: 130, 5   # (horizontal, vertical) Space between widgets
            padding: 20       # Space around the edges of the GridLayout

            Label:  #Label for number of players
                text: "No. Players"
                size_hint: 0.5, None
                height: 50
                color: "#e0e0e0ff"
                font_name: root.roboto_font  # Font Path "assets\\fonts\\RobotoSlab-Medium.ttf"
                font_size: "22dp"   
            Slider:  # Slider for the number of players
                id: plr_num_slider
                pos: "400dp", "100dp"
                min: 4  # Minimum no. players
                max: 15  # Maximum no. players
                value: 4  # Default value
                on_value: root.on_plr_slider_value(self)  # Function to adjust value
            Label:  # Label to shows the number as slider adjusts
                text: root.plr_num_val
                font: "200dp"
                color: "#e0e0e0ff"
                font_name: root.press_font  # Font Path "assets\\fonts\\PressStart2P-Regular.ttf"
                font_size: "25dp"

                
            ###########################################################################
            Label:
                text: "No. Mafia"
                size_hint: 0.5, None
                height: 50
                #pos_hint: {"center_x": 0.15, "center_y": 0.45}
                color: "#e0e0e0ff"
                font_name: root.roboto_font #"assets\\fonts\\RobotoSlab-Medium.ttf"
                font_size: "22dp"   
            Slider:
                id: maf_num_slider
                pos: "400dp", "100dp"
                #pos_hint: {"center_x": 0.35, "center_y": 0.45}
                min: 1
                max: 5
                value: 1
                on_value: root.on_maf_slider_value(self)
            Label:
                text: root.maf_num_val
                font: "200dp"
                #pos_hint: {"center_x": 0.475, "center_y": 0.45}
                color: "#e0e0e0ff"
                font_name: root.press_font #"assets\\fonts\\PressStart2P-Regular.ttf"
                font_size: "25dp"
            ###########################################################################
            Label:
                text: "Discussion Time"
                size_hint: 0.5, None
                height: 50
                #pos_hint: {"center_x": 0.15, "center_y": 0.45}
                color: "#e0e0e0ff"
                font_name: root.roboto_font #"assets\\fonts\\RobotoSlab-Medium.ttf"
                font_size: "22dp"   
            Slider:
                id: discussion_time_slider
                pos: "400dp", "100dp"
                #pos_hint: {"center_x": 0.35, "center_y": 0.45}
                min: 0
                max: 60
                value: 30
                on_value: root.on_time_slider_value(self)
            Label:
                text: root.discussion_time_val + "s"
                font: "200dp"
                #pos_hint: {"center_x": 0.475, "center_y": 0.45}
                color: "#e0e0e0ff"
                font_name: root.press_font #"assets\\fonts\\PressStart2P-Regular.ttf"
                font_size: "25dp"
            ###########################################################################
            Label:
                text: "Include Doctor?"
                size_hint: 0.5, None
                height: 50
                #pos_hint: {"center_x": 0.15, "center_y": 0.45}
                color: "#e0e0e0ff"
                font_name: root.roboto_font #"assets\\fonts\\RobotoSlab-Medium.ttf"
                font_size: "22dp"
            Switch:
                on_active: root.on_doc_swtich_active(self)
            Label:
            ###########################################################################
            Label:
                text: "Include Detective?"
                size_hint: 0.5, None
                height: 50
                #pos_hint: {"center_x": 0.15, "center_y": 0.45}
                color: "#e0e0e0ff"
                font_name: root.roboto_font #"assets\\fonts\\RobotoSlab-Medium.ttf"
                font_size: "22dp"
            Switch:
                on_active: root.on_det_swtich_active(self)
            Label:
            ############################################################################
            Label:
                text: "Anonymous Voting?"
                size_hint: 0.5, None
                height: 50
                #pos_hint: {"center_x": 0.15, "center_y": 0.45}
                color: "#e0e0e0ff"
                font_name: root.roboto_font #"assets\\fonts\\RobotoSlab-Medium.ttf"
                font_size: "22dp"
            Switch:
                on_active: root.on_anonymous_swtich_active(self)
            Label:
            ############################################################################
            Label:
                text: "Allow Skip Vote?"
                size_hint: 0.5, None
                height: 50
                #pos_hint: {"center_x": 0.15, "center_y": 0.45}
                color: "#e0e0e0ff"
                font_name: root.roboto_font #"assets\\fonts\\RobotoSlab-Medium.ttf"
                font_size: "22dp"
            Switch:
                on_active: root.on_skip_swtich_active(self)
            Label:
            ############################################################################
            Label:
                text: "Execute If Tie?"
                size_hint: 0.5, None
                height: 50
                #pos_hint: {"center_x": 0.15, "center_y": 0.45}
                color: "#e0e0e0ff"
                font_name: root.roboto_font #"assets\\fonts\\RobotoSlab-Medium.ttf"
                font_size: "22dp"
            Switch:
                on_active: root.on_execute_swtich_active(self)
            Label:
            ############################################################################
            Label:
                text: "Host Name"
                size_hint: 0.5, None
                height: 50
                #pos_hint: {"center_x": 0.15, "center_y": 0.55}
                color: "#e0e0e0ff"
                font_name: root.roboto_font #"assets\\fonts\\RobotoSlab-Medium.ttf"
                font_size: "22dp"
            TextInput:
                id: host_name_widget
                font_name: root.roboto_font
                on_text: root.on_host_name_enter(self)
            Label:
            ############################################################################
            Label:
                text: "Host Accent"
                size_hint: 0.5, None
                height: 50
                #pos_hint: {"center_x": 0.15, "center_y": 0.55}
                color: "#e0e0e0ff"
                font_name: root.roboto_font #"assets\\fonts\\RobotoSlab-Medium.ttf"
                font_size: "22dp"  
            TextInput:
                id: host_accent_widget
                font_name: root.roboto_font
                hint_text: "(au, uk, us, ca, in, za, ng)"
                on_text: root.on_host_accent_enter(self)

        Button:
            text: "PLAY"
            pos: "100dp", "200dp"
            background_normal: ''
            background_color: "#25AB58FF"
            color: "#e0e0e0ff"
            background_normal: ''
            background_color: "#25AB58FF"
            color: "#e0e0e0ff"
            size_hint: (0.3, 0.1)
            pos_hint: {"center_x": 0.5, "center_y": 0.1}
            on_press: 
                root.on_play()
            pos_hint: {"center_x": 0.5, "center_y": 0.1}
            on_press: 
                root.on_play()
                root.manager.transition.direction = 'left'
                root.manager.transition.duration = 1
                root.manager.current = 'screen_four'
            font_name: root.press_font #"assets\\fonts\\PressStart2P-Regular.ttf"
            font_size: "30dp"

        Button:
            text: "←"
            pos: "100dp", "200dp"
            color: "#e0e0e0ff"
            background_normal: ''
            background_color: "#676767"
            size_hint: (0.05, 0.05)
            pos_hint: {"center_x": 0.05, "center_y": 0.95}
            on_press:
                root.manager.transition.direction = 'right'
                root.manager.transition.duration = 1
                root.manager.current = 'screen_one'
            font_name: root.press_font #"assets\\fonts\\PressStart2P-Regular.ttf"
            font_size: "30dp"

<ScreenFour>:
    Label:
        text: "Players"
        size_hint: 0.5, None
        height: 50
        pos_hint: {"center_x": 0.5, "center_y": 0.95}
        #color: "#7b9fecff"
        color: "#d73612ff"
        font_name: root.rye_font #"assets\\fonts\\RobotoSlab-Medium.ttf"
        font_size: "50dp"

    Button:
        text: "PLAY"
        pos: "100dp", "200dp"
        color: "#e0e0e0ff"
        background_normal: ''
        background_color: "#25AB58FF"
        size_hint: (0.3, 0.1)
        pos_hint: {"center_x": 0.5, "center_y": 0.4}
        on_press: 
            root.start_game()
            root.manager.transition.direction = 'left'
            root.manager.transition.duration = 1
            root.manager.current = 'screen_five'
        font_name: root.press_font #"assets\\fonts\\PressStart2P-Regular.ttf"
        font_size: "30dp"

    Button:
        text: "←"
        pos: "100dp", "200dp"
        color: "#e0e0e0ff"
        background_normal: ''
        background_color: "#676767"
        size_hint: (0.1, 0.1)
        pos_hint: {"center_x": 0.1, "center_y": 0.9}
        on_press:
            root.manager.transition.direction = 'right'
            root.manager.transition.duration = 1
            root.manager.current = 'screen_three'
        font_name: root.press_font #"assets\\fonts\\PressStart2P-Regular.ttf"
        font_size: "30dp"

        #Button:
        #    text: "←"
        #    pos: "100dp", "200dp"
