<PlayerScreen>:
    name: 'player'
    
    MDLabel:
        text: "Players"
        pos_hint: {'center_x':0.5, 'center_y':0.85}
        size_hint: (0.7, None)
        halign: 'center'
        font_name: root.rye_font# "assets\\fonts\\Rye-Regular.ttf"
        color: "#F44336" # "#d73612ff"
        font_size: "60dp"
    
    ScrollView:
        #size: self.size
        adaptive_height: True
        halign: "center"
        valign: "top"
        pos_hint: {'center_x':0.5, 'center_y':0.5}
        size_hint: (0.9, 0.5)
        GridLayout:  # Layout for all the game's settings
            rows: 8
            cols: 2

            size_hint_y: None
            height: self.minimum_height
            width: self.minimum_width
            spacing: "5dp"
            padding: "5dp", "5dp", "5dp", "5dp"
            #position: (0.5, 0.95)

            MDTextField:
                id: name1
                hint_text: "Player #1"
                on_text: root.validate_text(self)

            MDTextField:
                id: name2
                hint_text: "Player #2"

                on_text: root.validate_text(self)
            MDTextField:
                id: name3
                hint_text: "Player #3"

                on_text: root.validate_text(self)
            MDTextField:
                id: name4
                hint_text: "Player #4"

                on_text: root.validate_text(self)
            MDTextField:
                id: name5
                hint_text: "Player #5"

                on_text: root.validate_text(self)
            MDTextField:
                id: name6
                hint_text: "Player #6"

                on_text: root.validate_text(self)
            MDTextField:
                id: name7
                hint_text: "Player #7"

                on_text: root.validate_text(self)
            MDTextField:
                id: name8
                hint_text: "Player #8"

                on_text: root.validate_text(self)
            MDTextField:
                id: name9
                hint_text: "Player #9"

                on_text: root.validate_text(self)
            MDTextField:
                id: name10
                hint_text: "Player #10"
                on_text: root.validate_text(self)

            MDTextField:
                id: name11
                hint_text: "Player #11"
                on_text: root.validate_text(self)

            MDTextField:
                id: name12
                hint_text: "Player #12"
                on_text: root.validate_text(self)

            MDTextField:
                id: name13
                hint_text: "Player #13"
                on_text: root.validate_text(self)

            MDTextField:
                id: name14
                hint_text: "Player #14"
                on_text: root.validate_text(self)

            MDTextField:
                id: name15
                hint_text: "Player #15"
                on_text: root.validate_text(self)

            MDTextField:
                id: name16
                hint_text: "Player #16"
                on_text: root.validate_text(self)

    MDRoundFlatIconButton:
        size_hint: (None, None)
        size: (dp(64), dp(64))
        pos_hint: {"center_x": 0.075, "center_y": 0.95}
        line_color: [0,0,0,0]

        on_release:
            root.manager.transition.direction = "right"
            root.manager.current = 'setup'
            print("Start Game")

        MDIcon:
            icon_size: dp(128)
            theme_text_color: "Custom"  # Set text color to custom
            text_color: "#F44336"  # Use accent color for the icon
            icon: "arrow-left-bold-circle-outline"
            icon_align: "center"
            size_hint: (None, None)
            size: (dp(64), dp(64))  # Set a size for the icon
            pos_hint: {"center_x": 0.5, "center_y": 0.5}  # Center the icon

    MDRectangleFlatButton:
        id: play
        text: "Continue"
        #font_name: root.press_font
        pos_hint: {'center_x':0.5, 'center_y':0.15}
        size_hint: (0.4, 0.1)
        font_size: "20dp"
        disabled: True

        on_release:
            root.manager.transition.direction = "left"
            root.manager.current = 'role'
            print("Start Game")