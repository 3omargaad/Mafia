<GameScreen>:
    name: 'game'

    MDLabel:
        id: dialogue
        text: "Please turn up your Volume."
        pos_hint: {'center_x':0.5, 'center_y':0.8}
        #size_hint: (0.7, 0.1)
        halign: 'center'
        #font_name: root.rye_font# "assets\\fonts\\Rye-Regular.ttf"
        font_name: root.roboto_font
        color: "#F44336" # "#d73612ff"
        font_size: "25dp"

    MDRectangleFlatButton:
        font_name: root.roboto_font
        text: "Action"
        id: action
        #font_name: root.press_font
        pos_hint: {'center_x':0.5, 'center_y':0.15}
        size_hint: (0.4, 0.1)
        font_size: "20dp"
        disabled: True

        on_press: root.on_press()
        on_release: root.on_release()

    MDRoundFlatIconButton:
        size_hint: (None, None)
        size: (dp(64), dp(64))
        pos_hint: {"center_x": 0.075, "center_y": 0.95}
        line_color: [0,0,0,0]

        on_release: root.quit(self)

        MDIcon:
            icon_size: dp(128)
            theme_text_color: "Custom"  # Set text color to custom
            text_color: "#F44336"  # Use accent color for the icon
            icon: "close-circle-outline"
            icon_align: "center"
            size_hint: (None, None)
            size: (dp(64), dp(64))  # Set a size for the icon
            pos_hint: {"center_x": 0.5, "center_y": 0.5}  # Center the icon

    ScrollView:
        adaptive_height: True
        halign: "center"
        valign: "top"
        pos_hint: {'center_x':0.5, 'center_y':0.5}
        size_hint: (0.9, 0.5)

        #size: self.size
        GridLayout:
            id: grid
            size_hint_y: None
            height: self.minimum_height
            width: self.minimum_width
            cols: 2
            spacing: "20dp"
            padding: "20dp"


            OneLineListItem:
                font_name: root.roboto_font
                opacity: 0
                disabled: True
                id: name1
                multiline: True
                value: 12
                text: "OnlyTwentyCharacters"
                secondary_text: "0 Votes"

                MDCheckbox:
                    id: check1

                MDIcon:
                    opacity: 0
                    id: vote1
                    icon_size: dp(128)
                    theme_text_color: "Custom"  # Set text color to custom
                    text_color: "#F44336"  # Use accent color for the icon
                    icon: "numeric-0-circle-outline"
                    icon_align: "right"
                    size_hint: (None, None)
                    size: (dp(64), dp(64))  # Set a size for the icon
                    pos_hint: {"center_x": 0.85, "center_y": 0.5}  # Center the icon
            
            OneLineListItem:
                font_name: root.roboto_font
                opacity: 0
                disabled: True
                id: name2
                multiline: True
                value: 12
                text: "OnlyTwentyCharacters"
