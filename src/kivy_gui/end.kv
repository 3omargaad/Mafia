<EndScreen>:
    name: 'end'

    MDLabel:
        id: good
        opacity: 0
        text: "Good Team Wins"
        pos_hint: {'center_x':0.5, 'center_y':0.85}
        #size_hint: (0.7, 0.1)
        halign: 'center'
        font_name: root.rye_font# "assets\\fonts\\Rye-Regular.ttf"
        font_size: "60dp"

    MDLabel:
        id: bad
        opacity: 0
        text: "Bad Team Wins"
        pos_hint: {'center_x':0.5, 'center_y':0.85}
        #size_hint: (0.7, 0.1)
        halign: 'center'
        font_name: root.rye_font# "assets\\fonts\\Rye-Regular.ttf"
        color: "#F44336" # "#d73612ff"
        font_size: "60dp"

    # MDLabel:
    #     id: result
    #     text: "Good Team wins!"
    #     pos_hint: {'center_x':0.5, 'center_y':0.3}
    #     #size_hint: (0.7, 0.1)
    #     halign: 'center'
    #     font_name: root.rye_font# "assets\\fonts\\Rye-Regular.ttf"
    #     color: "#F44336" # "#d73612ff"
    #     font_size: "30dp"
    
    MDLabel:
        font_name: root.roboto_font
        text: "Here are all the players roles..."
        pos_hint: {'center_x':0.5, 'center_y':0.3}
        halign: 'center'
        halign: 'center'
        size_hint: (0.7, 0.1)

    Image:
        id: win
        opacity: 0
        source: root.win_img
        pos_hint: {'center_x':0.5, 'center_y':0.6}
        size_hint: (0.6, 0.6)

    Image:
        id: lose
        opacity: 0
        source: root.lose_img
        pos_hint: {'center_x':0.5, 'center_y':0.6}
        size_hint: (0.6, 0.6)

    MDRectangleFlatButton:
        text: "Play Again"
        id: action
        #font_name: root.press_font
        pos_hint: {'center_x':0.5, 'center_y':0.15}
        size_hint: (0.4, 0.1)
        font_size: "20dp"

        on_release:
            root.manager.transition.direction = "down"
            root.manager.current = 'setup'
            print("Start Game")
