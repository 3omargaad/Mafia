<RoleScreen>:
    MDLabel:
        text: "Roles"
        pos_hint: {'center_x':0.5, 'center_y':0.85}
        size_hint: (0.7, None)
        halign: 'center'
        font_name: root.rye_font# "assets\\fonts\\Rye-Regular.ttf"
        color: "#F44336" # "#d73612ff"
        font_size: "60dp"
    
    MDRoundFlatIconButton:
        size_hint: (None, None)
        size: (dp(64), dp(64))
        pos_hint: {"center_x": 0.075, "center_y": 0.95}
        line_color: [0,0,0,0]

        on_release:
            root.manager.transition.direction = "right"
            root.manager.current = 'player'
            print("Start Game")

        MDIcon:
            icon_size: dp(128)
            theme_text_color: "Custom"  # Set text color to custom
            text_color: "#F44336"  # Use accent color for the icon
            icon: "arrow-left-bold-circle-outline"
            icon_align: "center"
            size_hint: (None, None)
            size: (dp(64), dp(64))  # Set a size for the icon
            pos_hint: {"center_x": 0.5, "center_y": 0.5}  # Center the icon
    
    MDRectangleFlatButton:
        text: "Play"
        id: play
        #font_name: root.press_font
        pos_hint: {'center_x':0.5, 'center_y':0.15}
        size_hint: (0.4, 0.1)
        font_size: "20dp"
        disabled: True

        on_release:
            root.manager.transition.direction = "up"
            root.manager.current = 'game'
            print("Start Game")


    ScrollView:
        adaptive_height: True
        halign: "center"
        valign: "top"
        pos_hint: {'center_x':0.5, 'center_y':0.5}
        size_hint: (0.9, 0.5)

        GridLayout:
            id: cards
            rows: 16
            cols: 1

            size_hint_y: None
            height: self.minimum_height
            width: self.minimum_width
            spacing: "20dp"
            padding: "20dp"
            TwoLineAvatarListItem:
                id: name1
                value: 1
                text: "Tap to Reveal"
                secondary_text: "Tap to Reveal"
                IconLeftWidget:
                    icon_size: dp(32)
                    id: icon1
                    theme_text_color: "Custom"  # Set text color to custom
                    text_color: "#F44336"  # Use accent color for the icon
            
            TwoLineAvatarListItem:
                id: name2
                value: 2
                text: "Tap to Reveal"
                secondary_text: "Tap to Reveal"

                IconLeftWidget:
                    icon_size: dp(32)
                    id: icon2
                    theme_text_color: "Custom"  # Set text color to custom
                    text_color: "#F44336"  # Use accent color for the icon
            
            TwoLineAvatarListItem:
                id: name3
                value: 3
                text: "Tap to Reveal"
                secondary_text: "Tap to Reveal"

                IconLeftWidget:
