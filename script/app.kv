<GameScreen>:
    ScrollView:
        size: self.size
        GridLayout:
            size_hint_y: None
            height: self.minimum_height
            width: self.minimum_width
            cols: 2
            spacing: "20dp"
            padding: "20dp"

            MDCard:
                MDIcon:
                MDLabel:
                    text: "Player #1"
                    #align: "center"
                    pos_hint: {'center_x':0.5, 'center_y':0.4}
                    size_hint: (None, None)
                MDLabel:
                    text: "Alive"
                    color: "#36F456"
                    #align: "center"
                    pos_hint: {'center_x':0.5, 'center_y':0.25}
                    size_hint: (None, None)

            MDCard:
                MDLabel:
                    text: "Player #2"
                    #align: "center"
                    pos_hint: {'center_x':0.5, 'center_y':0.4}
                    size_hint: (None, None)
                MDLabel:
                    text: "Dead"
                    color: "#F44336"
                    #align: "center"
                    pos_hint: {'center_x':0.5, 'center_y':0.25}
                    size_hint: (None, None)

            MDCard:

            MDCard:
            MDCard:

            MDCard:
            MDCard:

            MDCard:
            MDCard:

            MDCard:
            MDCard:

            MDCard:
            MDCard:

            MDCard:
            MDCard:
