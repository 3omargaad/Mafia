<BackButton>:
    disabled: False

<TwoLineAvatarListItem>:
    on_release: self.parent.parent.parent.show_role(self)


<MDTextField>:
    max_text_length: 20

<IconLeftWidget>:
    icon: "account-circle-outline"


<MDRectangleFlatButton>:
    allow_hover: True
    hover_visible: True
    on_press:
        self.parent.click()
<MDRoundFlatIconButton>:
    on_press:
        self.parent.click()
#
    #on_leave:
    #    self.parent.hover_off()

<MDSwitch>:
    on_active: 
        self.parent.toggle(self)


<MDCard>:
    orientation: "vertical"
    padding: "8dp"
    size_hint: 1, None
    height: "120dp"
    elevation: 5
    border_radius: 20
    radius: [15]

<MDTextField>:
    size_hint: (0.5, None)
    padding: "5dp", "5dp"
    disabled: True
    opacity: 0

<LoginScreen>:
    name: 'login'

    MDLabel:
        text: "Mafia"
        pos_hint: {'center_x':0.5, 'center_y':0.85}
        size_hint: (0.7, None)
        halign: 'center'
        font_name: root.rye_font# "assets\\fonts\\Rye-Regular.ttf"
        color: "#F44336" # "#d73612ff"
        font_size: "60dp"

    MDTextField:
        hint_text: "Username"
        pos_hint: {'center_x':0.5, 'center_y':0.55}
        disabled: False
        size_hint: (0.5, None)
        opacity: 1


    MDTextField:
        hint_text: "Password"
        password: True
        pos_hint: {'center_x':0.5, 'center_y':0.45}
        disabled: False
        size_hint: (0.5, None)
        opacity: 1

    
    MDRectangleFlatButton:
        text: "Login/Signup"
        #font_name: root.press_font
        pos_hint: {'center_x':0.5, 'center_y':0.275}
        size_hint: (0.4, 0.1)
        font_size: "20dp"

        on_release: 
            root.account()

    MDRectangleFlatButton:
        text: "Play as Guest"
        #font_name: root.press_font
        pos_hint: {'center_x':0.5, 'center_y':0.15}
        size_hint: (0.4, 0.1)
        font_size: "20dp"

        on_release:
            root.manager.transition.direction = "left"
            root.manager.current = 'setup'
            print("Start Game")

<SetupScreen>:
    name: 'setup'

    MDLabel:
        text: "Game Setup"
        pos_hint: {'center_x':0.5, 'center_y':0.85}
        size_hint: (0.7, None)
        halign: 'center'
        font_name: root.rye_font# "assets\\fonts\\Rye-Regular.ttf"
        color: "#F44336" # "#d73612ff"
        font_size: "60dp"

    MDLabel:
        text: "No. Players (" + str(root.plr_num) + ")"
        pos_hint: {'center_x':0.4, 'center_y':0.675}
        size_hint: (0.6, None)

    MDSlider:
        pos_hint: {'center_x':0.6, 'center_y':0.675}
        min: 4
        max: 16
        step: 1
        size_hint: (0.4, None)
        on_value: 
            root.slide()
            root.on_plr_slider_value(self)

    MDLabel:
        text: "No. Mafia (" + str(root.maf_num) + ")"
        pos_hint: {'center_x':0.4, 'center_y':0.575}
        size_hint: (0.6, None)

    MDSlider:
        pos_hint: {'center_x':0.6, 'center_y':0.575}
        min: 1
        max: root.max_maf
        step: 1
        size_hint: (0.4, None)
        on_value: root.on_maf_slider_value(self)

    MDLabel:
        text: "Add Doctor?"
        pos_hint: {'center_x':0.175, 'center_y':0.46}
        size_hint: (0.25, None)

    MDSwitch:
        pos_hint: {'center_x':0.325, 'center_y':0.45}
        on_active:
            root.on_include_doc_switch_active(self)

    
    MDLabel:
        text: "Add Detective?"
        pos_hint: {'center_x':0.175, 'center_y':0.385}
        size_hint: (0.25, None)
    
    MDSwitch:
        pos_hint: {'center_x':0.325, 'center_y':0.375}
        on_active:
            root.on_include_det_switch_active(self)

    MDLabel:
        text: "Anonymous Vote?"
        pos_hint: {'center_x':0.175, 'center_y':0.3}
        size_hint: (0.25, None)
    
    MDSwitch:
        pos_hint: {'center_x':0.325, 'center_y':0.3}
        on_active:

    MDLabel:
        text: "Skip Vote?"
        pos_hint: {'center_x':0.6, 'center_y':0.46}
        size_hint: (0.25, None)
    
    MDSwitch:
        pos_hint: {'center_x':0.75, 'center_y':0.45}
        on_active:

    MDLabel:
        text: "Execute If Tie?"
        pos_hint: {'center_x':0.6, 'center_y':0.385}
        size_hint: (0.25, None)

    MDSwitch:
        pos_hint: {'center_x':0.75, 'center_y':0.375}
        on_active:
    
    MDRoundFlatIconButton:
        size_hint: (None, None)
        size: (dp(64), dp(64))
        pos_hint: {"center_x": 0.075, "center_y": 0.95}
        line_color: [0,0,0,0]

        on_release:
            root.manager.transition.direction = "right"
            root.manager.current = 'login'
            print("Start Game")

        MDIcon:
            icon_size: dp(128)
            theme_text_color: "Custom"  # Set text color to custom
            text_color: "#F44336"  # Use accent color for the icon
            icon: "arrow-left-bold-circle-outline"
            icon_align: "center"
            size_hint: (None, None)
            size: (dp(64), dp(64))  # Set a size for the icon
            pos_hint: {"center_x": 0.5, "center_y": 0.5}  # Center the icon

    
    MDRectangleFlatButton:
        text: "Continue"
        #font_name: root.press_font
        pos_hint: {'center_x':0.5, 'center_y':0.15}
        size_hint: (0.4, 0.1)
        font_size: "20dp"

        on_release:
            root.on_continue(self)
            root.manager.transition.direction = "left"
            root.manager.current = 'player'
            print("Start Game")

<PlayerScreen>:
    name: 'player'

    
    MDLabel:
        text: "Players"
        pos_hint: {'center_x':0.5, 'center_y':0.85}
        size_hint: (0.7, None)
        halign: 'center'
        font_name: root.rye_font# "assets\\fonts\\Rye-Regular.ttf"
        color: "#F44336" # "#d73612ff"
        font_size: "60dp"

    
    ScrollView:
        #size: self.size
        adaptive_height: True
        halign: "center"
        valign: "top"
        pos_hint: {'center_x':0.5, 'center_y':0.5}
        size_hint: (0.9, 0.5)
        GridLayout:  # Layout for all the game's settings
            rows: 8
            cols: 2

            size_hint_y: None
            height: self.minimum_height
            width: self.minimum_width
            spacing: "5dp"
            padding: "5dp", "5dp", "5dp", "5dp"
            #position: (0.5, 0.95)

            MDTextField:
                id: name1
                hint_text: "Player #1"

            MDTextField:
                id: name2
                hint_text: "Player #2"

            MDTextField:
                id: name3
                hint_text: "Player #3"

            MDTextField:
                id: name4
                hint_text: "Player #4"

            MDTextField:
                id: name5
                hint_text: "Player #5"

            MDTextField:
                id: name6
                hint_text: "Player #6"

            MDTextField:
                id: name7
                hint_text: "Player #7"

            MDTextField:
                id: name8
                hint_text: "Player #8"

            MDTextField:
                id: name9
                hint_text: "Player #9"

            MDTextField:
                id: name10
                hint_text: "Player #10"

            MDTextField:
                id: name11
                hint_text: "Player #11"

            MDTextField:
                id: name12
                hint_text: "Player #12"

            MDTextField:
                id: name13
                hint_text: "Player #13"

            MDTextField:
                id: name14
                hint_text: "Player #14"

            MDTextField:
                id: name15
                hint_text: "Player #15"

            MDTextField:
                id: name16
                hint_text: "Player #16"

    MDRoundFlatIconButton:
        size_hint: (None, None)
        size: (dp(64), dp(64))
        pos_hint: {"center_x": 0.075, "center_y": 0.95}
        line_color: [0,0,0,0]

        on_release:
            root.manager.transition.direction = "right"
            root.manager.current = 'setup'
            print("Start Game")

        MDIcon:
            icon_size: dp(128)
            theme_text_color: "Custom"  # Set text color to custom
            text_color: "#F44336"  # Use accent color for the icon
            icon: "arrow-left-bold-circle-outline"
            icon_align: "center"
            size_hint: (None, None)
            size: (dp(64), dp(64))  # Set a size for the icon
            pos_hint: {"center_x": 0.5, "center_y": 0.5}  # Center the icon

    MDRectangleFlatButton:
        text: "Play"
        #font_name: root.press_font
        pos_hint: {'center_x':0.5, 'center_y':0.15}
        size_hint: (0.4, 0.1)
        font_size: "20dp"

        on_release:
            root.manager.transition.direction = "left"
            root.manager.current = 'role'
            print("Start Game")

<RoleScreen>:
    MDLabel:
        text: "Roles"
        pos_hint: {'center_x':0.5, 'center_y':0.85}
        size_hint: (0.7, None)
        halign: 'center'
        font_name: root.rye_font# "assets\\fonts\\Rye-Regular.ttf"
        color: "#F44336" # "#d73612ff"
        font_size: "60dp"
    
    MDRoundFlatIconButton:
        size_hint: (None, None)
        size: (dp(64), dp(64))
        pos_hint: {"center_x": 0.075, "center_y": 0.95}
        line_color: [0,0,0,0]

        on_release:
            root.manager.transition.direction = "right"
            root.manager.current = 'player'
            print("Start Game")

        MDIcon:
            icon_size: dp(128)
            theme_text_color: "Custom"  # Set text color to custom
            text_color: "#F44336"  # Use accent color for the icon
            icon: "arrow-left-bold-circle-outline"
            icon_align: "center"
            size_hint: (None, None)
            size: (dp(64), dp(64))  # Set a size for the icon
            pos_hint: {"center_x": 0.5, "center_y": 0.5}  # Center the icon
    
    MDRectangleFlatButton:
        text: "Play"
        #font_name: root.press_font
        pos_hint: {'center_x':0.5, 'center_y':0.15}
        size_hint: (0.4, 0.1)
        font_size: "20dp"
        disabled: True

        on_release:
            root.manager.transition.direction = "left"
            root.manager.current = 'role'
            print("Start Game")


    ScrollView:
        adaptive_height: True
        halign: "center"
        valign: "top"
        pos_hint: {'center_x':0.5, 'center_y':0.5}
        size_hint: (0.9, 0.5)

        GridLayout:
            rows: 16
            cols: 1

            size_hint_y: None
            height: self.minimum_height
            width: self.minimum_width
            spacing: "20dp"
            padding: "20dp"
            TwoLineAvatarListItem:
                id: name1
                value: 1
                text: "Tap to Reveal"
                secondary_text: "Tap to Reveal"
                IconLeftWidget:
                    icon_size: dp(32)
                    id: icon1
                    theme_text_color: "Custom"  # Set text color to custom
                    text_color: "#F44336"  # Use accent color for the icon
            
            TwoLineAvatarListItem:
                id: name2
                value: 2
                text: "Tap to Reveal"
                secondary_text: "Tap to Reveal"

                IconLeftWidget:
                    icon_size: dp(32)
                    id: icon2
                    theme_text_color: "Custom"  # Set text color to custom
                    text_color: "#F44336"  # Use accent color for the icon
            
            TwoLineAvatarListItem:
                id: name3
                value: 3
                text: "Tap to Reveal"
                secondary_text: "Tap to Reveal"

                IconLeftWidget:
                    icon_size: dp(32)
